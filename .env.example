# Template de variáveis de ambiente para integração com o ERP UAU (Senior Cloud).
# Copie para `.env` e preencha com os valores reais — NÃO versionar `.env`.
# Somente a máquina Windows alcança o endpoint UAU.

# URL base da API UAU (Senior Cloud).
UAU_BASE_URL=https://seu-endpoint-uau

# Versão da API UAU utilizada nas chamadas (default "1" se omitido).
UAU_API_VERSION=1

# Usuário de autenticação (Login) na API UAU.
UAU_USUARIO=seu_usuario

# Senha do usuário acima. Nunca commitar valor real.
UAU_SENHA=sua_senha

# Header X-INTEGRATION-Authorization exigido pela API UAU.
UAU_X_INTEGRATION=seu_x_integration

# Filtro opcional de empresa (client-side, aplicado em _uau_parse_recebiveis).
# Deixe vazio para não filtrar por empresa.
UAU_EMPRESA=

# Filtro opcional de obra (client-side, aplicado em _uau_parse_recebiveis).
# Deixe vazio para não filtrar por obra.
UAU_OBRA=

# Timeout (segundos) das requisições HTTP para a API UAU.
UAU_HTTP_TIMEOUT=30

# Valor mínimo (R$) de parcela vencida para entrar no painel. Filtra por
# PARCELA INDIVIDUAL, não pelo total da dívida do cliente.
# Default 0 = não filtra nada.
# CUIDADO: mudar esse valor no meio do histórico de relatórios distorce
# recovery_rate e demais KPIs — um cliente pode "sumir" do painel não porque
# pagou, mas porque suas parcelas vencidas caíram abaixo do novo mínimo.
UAU_VALOR_MINIMO=0
